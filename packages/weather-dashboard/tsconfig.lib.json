{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2020"
    ],
    "jsx": "react-jsx",
    "types": [
      "node",
      "jest",
      "vite/client"
    ],
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": [
    "src",
    "vite.config.ts"
  ]
}
